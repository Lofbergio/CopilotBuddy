<Window x:Class="Bots.Gatherbuddy.GatherBuddySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GatherBuddy Settings" Width="520" Height="580"
        Background="#FF2D2D30"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <FrameworkElement.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF3F3F46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <!-- ═══ ComboBox ToggleButton template (dark) ═══ -->
        <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="#FF3F3F46" BorderBrush="#FF555555" BorderThickness="1" CornerRadius="2"/>
                <Border Grid.Column="0" Margin="1"
                        Background="#FF3F3F46" BorderThickness="0" CornerRadius="2,0,0,2"/>
                <Path x:Name="Arrow" Grid.Column="1"
                      Fill="#FFCCCCCC" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#FF505058"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#FF505058"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ═══ ComboBox style (full dark ControlTemplate) ═══ -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggleButton}"
                                          Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="6,3,23,3" VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#FF3F3F46" BorderBrush="#FF555555" BorderThickness="1"/>
                                    <ScrollViewer Margin="2,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF3F3F46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF007ACC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Button (dark) ═══ -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3F3F46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
        </Style>

        <!-- ═══ TabItem (full dark ControlTemplate) ═══ -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="#FF3F3F46"
                                BorderBrush="#FF555555" BorderThickness="1,1,1,0"
                                Padding="10,4" Margin="0,0,2,0"
                                CornerRadius="3,3,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FF007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#FF505058"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </FrameworkElement.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="#FF2D2D30" BorderBrush="#FF555555">
            <!-- ══════════════════════════════════════════════════════ -->
            <!-- TAB 1: GENERAL SETTINGS                               -->
            <!-- ══════════════════════════════════════════════════════ -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FF2D2D30">
                    <StackPanel>
                        <!-- ═══ GATHERING ═══ -->
                        <GroupBox Header="Gathering">
                            <StackPanel Margin="4">
                                <CheckBox x:Name="chkGatherHerbs" Content="Gather Herbs"
                                          Margin="0,4" IsChecked="{Binding GatherHerbs, Mode=TwoWay}"/>
                                <CheckBox x:Name="chkGatherMinerals" Content="Gather Minerals"
                                          Margin="0,4" IsChecked="{Binding GatherMinerals, Mode=TwoWay}"/>
                                <CheckBox x:Name="chkGatherChests" Content="Gather Chests (Treasure)"
                                          Margin="0,4" IsChecked="{Binding GatherChests, Mode=TwoWay}"/>
                                <CheckBox x:Name="chkFaceNodes" Content="Face Nodes Before Gathering"
                                          Margin="0,4" IsChecked="{Binding FaceNodes, Mode=TwoWay}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ NAVIGATION ═══ -->
                        <GroupBox Header="Navigation">
                            <StackPanel Margin="4">
                                <DockPanel Margin="0,4">
                                    <Label Content="Path Type:" Width="120"/>
                                    <ComboBox x:Name="cmbPathType"
                                              SelectedIndex="{Binding PathingTypeIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="Circle"/>
                                        <ComboBoxItem Content="Bounce"/>
                                    </ComboBox>
                                </DockPanel>

                                <DockPanel Margin="0,4">
                                    <Label Content="Detection Range:" Width="120"/>
                                    <Label Content="{Binding ElementName=sldDetectionRange, Path=Value}"
                                           ContentStringFormat="{}{0:F0} yds" Width="55" HorizontalContentAlignment="Right"/>
                                    <Slider x:Name="sldDetectionRange" Minimum="20" Maximum="150"
                                            TickPlacement="BottomRight" TickFrequency="10"
                                            AutoToolTipPlacement="TopLeft" SmallChange="5"
                                            Value="{Binding NodeDetectionRange, Mode=TwoWay}"/>
                                </DockPanel>

                                <DockPanel Margin="0,4">
                                    <Label Content="Height Modifier:" Width="120"/>
                                    <Label Content="{Binding ElementName=sldHeightModifier, Path=Value}"
                                           ContentStringFormat="{}{0:F0} yds" Width="55" HorizontalContentAlignment="Right"/>
                                    <Slider x:Name="sldHeightModifier" Minimum="-300" Maximum="300"
                                            TickPlacement="BottomRight" TickFrequency="25"
                                            AutoToolTipPlacement="TopLeft" SmallChange="5"
                                            Value="{Binding HeightModifier, Mode=TwoWay}"/>
                                </DockPanel>

                                <CheckBox x:Name="chkRandomizeHotspots" Content="Randomize Hotspot Order"
                                          Margin="0,4" IsChecked="{Binding RandomizeHotspots, Mode=TwoWay}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ COMBAT ═══ -->
                        <GroupBox Header="Combat / Loot">
                            <StackPanel Margin="4">
                                <CheckBox x:Name="chkLootMobs" Content="Loot Killed Mobs"
                                          Margin="0,4" IsChecked="{Binding LootMobs, Mode=TwoWay}"/>
                                <CheckBox x:Name="chkIgnoreElites" Content="Ignore Elite Mobs"
                                          Margin="0,4" IsChecked="{Binding IgnoreElites, Mode=TwoWay}"/>
                                <CheckBox x:Name="chkSkinMobs" Content="Skin Killed Mobs (Skinning)"
                                          Margin="0,4" IsChecked="{Binding SkinMobs, Mode=TwoWay}"/>

                                <DockPanel Margin="0,4">
                                    <Label Content="Loot Radius:" Width="120"/>
                                    <Label Content="{Binding ElementName=sldLootRadius, Path=Value}"
                                           ContentStringFormat="{}{0:F0} yds" Width="55" HorizontalContentAlignment="Right"/>
                                    <Slider x:Name="sldLootRadius" Minimum="5" Maximum="60"
                                            TickPlacement="BottomRight" TickFrequency="5"
                                            AutoToolTipPlacement="TopLeft" SmallChange="5"
                                            Value="{Binding LootRadius, Mode=TwoWay}"/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ ANTI-NINJA ═══ -->
                        <GroupBox Header="Anti-Ninja">
                            <StackPanel Margin="4">
                                <CheckBox x:Name="chkNoNinja" Content="Don't Steal Nodes From Other Players"
                                          Margin="0,4" IsChecked="{Binding NoNinja, Mode=TwoWay}"/>

                                <DockPanel Margin="0,4">
                                    <Label Content="Blacklist Timer:" Width="120"/>
                                    <Label Content="{Binding ElementName=sldBlacklistTimer, Path=Value}"
                                           ContentStringFormat="{}{0:F0} sec" Width="55" HorizontalContentAlignment="Right"/>
                                    <Slider x:Name="sldBlacklistTimer" Minimum="5" Maximum="120"
                                            TickPlacement="BottomRight" TickFrequency="10"
                                            AutoToolTipPlacement="TopLeft" SmallChange="5"
                                            Value="{Binding BlacklistTimerValue, Mode=TwoWay}"/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ VENDOR/REPAIR ═══ -->
                        <GroupBox Header="Vendor / Repair">
                            <StackPanel Margin="4">
                                <CheckBox x:Name="chkVendorWhenFull" Content="Go To Vendor When Bags Full"
                                          Margin="0,4" IsChecked="{Binding VendorWhenFull, Mode=TwoWay}"/>

                                <DockPanel Margin="0,4" IsEnabled="{Binding IsChecked, ElementName=chkVendorWhenFull}">
                                    <Label Content="Min Free Slots:" Width="120"/>
                                    <Label Content="{Binding ElementName=sldMinFreeSlots, Path=Value}"
                                           ContentStringFormat="{}{0:F0}" Width="55" HorizontalContentAlignment="Right"/>
                                    <Slider x:Name="sldMinFreeSlots" Minimum="1" Maximum="10"
                                            TickPlacement="BottomRight" TickFrequency="1"
                                            AutoToolTipPlacement="TopLeft" SmallChange="1"
                                            Value="{Binding MinFreeBagSlotsValue, Mode=TwoWay}"/>
                                </DockPanel>

                                <CheckBox x:Name="chkFindVendorsAuto" Content="Find Vendors Automatically"
                                          Margin="0,4" IsChecked="{Binding FindVendorsAutomatically, Mode=TwoWay}"/>

                                <CheckBox x:Name="chkRepairAtVendor" Content="Repair At Vendor"
                                          Margin="0,4" IsChecked="{Binding RepairAtVendor, Mode=TwoWay}"/>

                                <DockPanel Margin="0,4" IsEnabled="{Binding IsChecked, ElementName=chkRepairAtVendor}">
                                    <Label Content="Repair Below:" Width="120"/>
                                    <Label Content="{Binding ElementName=sldRepairPct, Path=Value}"
                                           ContentStringFormat="{}{0:F0}%" Width="55" HorizontalContentAlignment="Right"/>
                                    <Slider x:Name="sldRepairPct" Minimum="5" Maximum="50"
                                            TickPlacement="BottomRight" TickFrequency="5"
                                            AutoToolTipPlacement="TopLeft" SmallChange="5"
                                            Value="{Binding RepairDurabilityPercentValue, Mode=TwoWay}"/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ SELL QUALITY ═══ -->
                        <GroupBox Header="Sell Quality Filters">
                            <StackPanel Margin="4">
                                <Label Content="Sell items of these qualities at vendor:" FontSize="11" Foreground="#FF888888"/>
                                <WrapPanel Margin="0,4">
                                    <CheckBox Content="Grey" Margin="0,0,12,0"
                                              IsChecked="{Binding SellGrey, Mode=TwoWay}"/>
                                    <CheckBox Content="White" Margin="0,0,12,0"
                                              IsChecked="{Binding SellWhite, Mode=TwoWay}"/>
                                    <CheckBox Content="Green" Margin="0,0,12,0"
                                              IsChecked="{Binding SellGreen, Mode=TwoWay}"/>
                                    <CheckBox Content="Blue" Margin="0,0,12,0"
                                              IsChecked="{Binding SellBlue, Mode=TwoWay}"/>
                                    <CheckBox Content="Purple" Margin="0,0,12,0"
                                              IsChecked="{Binding SellPurple, Mode=TwoWay}"/>
                                </WrapPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ MAIL ═══ -->
                        <GroupBox Header="Mail">
                            <StackPanel Margin="4">
                                <CheckBox x:Name="chkMailToAlt" Content="Mail Items To Alt"
                                          Margin="0,4" IsChecked="{Binding MailToAlt, Mode=TwoWay}"/>
                                <DockPanel Margin="0,4" IsEnabled="{Binding IsChecked, ElementName=chkMailToAlt}">
                                    <Label Content="Recipient:" Width="120"/>
                                    <TextBox Text="{Binding MailRecipient, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <Label Content="Mail items of these qualities:" FontSize="11"
                                       Foreground="#FF888888" Margin="0,4,0,0"
                                       IsEnabled="{Binding IsChecked, ElementName=chkMailToAlt}"/>
                                <WrapPanel Margin="0,4" IsEnabled="{Binding IsChecked, ElementName=chkMailToAlt}">
                                    <CheckBox Content="Grey" Margin="0,0,12,0"
                                              IsChecked="{Binding MailGrey, Mode=TwoWay}"/>
                                    <CheckBox Content="White" Margin="0,0,12,0"
                                              IsChecked="{Binding MailWhite, Mode=TwoWay}"/>
                                    <CheckBox Content="Green" Margin="0,0,12,0"
                                              IsChecked="{Binding MailGreen, Mode=TwoWay}"/>
                                    <CheckBox Content="Blue" Margin="0,0,12,0"
                                              IsChecked="{Binding MailBlue, Mode=TwoWay}"/>
                                    <CheckBox Content="Purple" Margin="0,0,12,0"
                                              IsChecked="{Binding MailPurple, Mode=TwoWay}"/>
                                </WrapPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ DEATH / SAFETY ═══ -->
                        <GroupBox Header="Death / Safety">
                            <StackPanel Margin="4">
                                <CheckBox x:Name="chkUseSpiritHealer" Content="Use Spirit Healer (skip corpse run)"
                                          Margin="0,4" IsChecked="{Binding UseSpiritHealer, Mode=TwoWay}"/>
                                <CheckBox x:Name="chkWaitRezSickness" Content="Wait Out Rez Sickness"
                                          Margin="0,4" IsChecked="{Binding WaitRezSickness, Mode=TwoWay}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ SESSION TIMER ═══ -->
                        <GroupBox Header="Session Timer">
                            <StackPanel Margin="4">
                                <DockPanel Margin="0,4">
                                    <Label Content="Botting Hours:" Width="120"/>
                                    <Label Content="{Binding ElementName=sldBottingHours, Path=Value}"
                                           ContentStringFormat="{}{0:F1} hrs" Width="55" HorizontalContentAlignment="Right"/>
                                    <Slider x:Name="sldBottingHours" Minimum="0" Maximum="24"
                                            TickPlacement="BottomRight" TickFrequency="1"
                                            AutoToolTipPlacement="TopLeft" SmallChange="0.5"
                                            Value="{Binding BottingHours, Mode=TwoWay}"/>
                                </DockPanel>
                                <Label Content="(0 = no limit)" FontSize="10" Foreground="#FF888888" Margin="120,0,0,0"/>
                                <CheckBox x:Name="chkHearthAndExit" Content="Hearthstone &amp; Exit on Timer"
                                          Margin="0,4" IsChecked="{Binding HearthAndExit, Mode=TwoWay}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- TAB 2: NODE SELECTION                                 -->
            <!-- ══════════════════════════════════════════════════════ -->
            <TabItem Header="Node Selection">
                <Grid Background="#FF2D2D30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ── HERBS ── -->
                    <GroupBox Header="Herbs" Grid.Row="0" Margin="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="4,2">
                                <Button Content="Select All" Width="75" Height="22" Margin="0,0,4,0"
                                        Click="btnSelectAllHerbs_Click"/>
                                <Button Content="Unselect All" Width="80" Height="22"
                                        Click="btnUnselectAllHerbs_Click"/>
                                <Label Content="Herbs" Foreground="#FF888888" FontSize="11" Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding HerbItems}"
                                     Background="#FF1E1E1E" Foreground="White"
                                     BorderBrush="#FF555555"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Content="{Binding DisplayName}"
                                                  Foreground="White" Margin="2,1"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </GroupBox>

                    <!-- ── MINERALS ── -->
                    <GroupBox Header="Minerals" Grid.Row="1" Margin="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="4,2">
                                <Button Content="Select All" Width="75" Height="22" Margin="0,0,4,0"
                                        Click="btnSelectAllMinerals_Click"/>
                                <Button Content="Unselect All" Width="80" Height="22"
                                        Click="btnUnselectAllMinerals_Click"/>
                                <Label Content="Minerals" Foreground="#FF888888" FontSize="11" Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding MineralItems}"
                                     Background="#FF1E1E1E" Foreground="White"
                                     BorderBrush="#FF555555"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Content="{Binding DisplayName}"
                                                  Foreground="White" Margin="2,1"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══ BUTTONS ═══ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save &amp; Close" Width="100" Height="26" Margin="0,0,8,0"
                    Click="btnSaveAndClose_Click"/>
            <Button Content="Cancel" Width="80" Height="26"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
