<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows7.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <PlatformTarget>x86</PlatformTarget>
    <Platforms>x86</Platforms>
    <StartupObject>CopilotBuddy.UI.App</StartupObject>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- Application icon (barre des tâches + exe) -->
    <ApplicationIcon>Resources\bender.ico</ApplicationIcon>
    <!-- FileVersion = right-click Properties → Details. AssemblyVersion intentionally omitted (BAML crash on .NET 10) -->
    <FileVersion>1.5.2.0</FileVersion>
    <!-- Exclude satellite assemblies (localization folders like cs, de, es, fr, it, ja, ko, pl, pt-BR, ru, tr, zh-Hans, zh-Hant) -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <!-- Force all NuGet package assemblies to be copied to the output directory,
         even those not transitively used by the application's compiled code.
         This is needed because the runtime SourceCompiler resolves plugin
         references from $(OutDir), including WCF (System.ServiceModel.*) and
         System.Drawing.Common which the WPF app itself does not import. Without
         this, those DLLs would be missing from bin\Debug\net10.0-windows7.0\
         and any plugin compiled at runtime using WCF / System.Drawing would fail. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Release'">
    <Optimize>true</Optimize>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <!-- Exclude standalone tool projects from the main bot build -->
  <ItemGroup>
    <Compile Remove="Tools\**" />
    <EmbeddedResource Remove="Tools\**" />
    <None Remove="Tools\**" />
    <Content Remove="Tools\**" />
  </ItemGroup>

  <!-- Exclude runtime output/ folder from the build (Bots/, Plugins/, Routines/, profiles, data, etc. live next to the exe at runtime, not in the project) -->
  <ItemGroup>
    <Compile Remove="output\**" />
    <EmbeddedResource Remove="output\**" />
    <None Remove="output\**" />
    <Content Remove="output\**" />
  </ItemGroup>

  <ItemGroup>
    <Page Remove="UI\App.xaml" />
  </ItemGroup>

  <ItemGroup>
    <ApplicationDefinition Include="UI\App.xaml" />
  </ItemGroup>

  <!-- PostBuild: move satellite culture folders into Languages/ subdir (HB pattern) -->
  <Target Name="MoveSatelliteAssemblies" AfterTargets="Build">
    <Exec Command="if exist &quot;$(OutputPath)Languages\&quot; rmdir /S /Q &quot;$(OutputPath)Languages&quot;
for /D %%c in (&quot;$(OutputPath)*&quot;) do (
  if exist &quot;%%c\CopilotBuddy.resources.dll&quot; (
    if not exist &quot;$(OutputPath)Languages\%%~nc&quot; mkdir &quot;$(OutputPath)Languages\%%~nc&quot;
    move /Y &quot;%%c\CopilotBuddy.resources.dll&quot; &quot;$(OutputPath)Languages\%%~nc\&quot;
    rmdir /S /Q &quot;%%c&quot;
    echo [Localization] Moved %%~nc satellite to Languages\
  )
)
exit /b 0"/>
  </Target>

  <!-- Resources (icons) -->
  <ItemGroup>
    <Resource Include="Resources\bender.ico" />
    <Resource Include="Resources\*.png" />
  </ItemGroup>

  <!-- Reference to fasmdll_managed.dll for FASM assembler -->
  <ItemGroup>
    <Reference Include="fasmdll_managed">
      <HintPath>Lib\fasmdll_managed.dll</HintPath>
    </Reference>
    <!-- SQLite with SEE (from HB) for encrypted Data.bin -->
    <Reference Include="System.Data.SQLite">
      <HintPath>Lib\System.Data.SQLite.dll</HintPath>
    </Reference>
  </ItemGroup>

  <!-- Native Navigation.dll: place manually next to exe. Loaded via [DllImport] P/Invoke. -->

  <ItemGroup>
    <PackageReference Include="MahApps.Metro" Version="2.4.11" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Scripting" Version="4.12.0" />
    <PackageReference Include="System.Drawing.Common" Version="10.0.0" />
    <PackageReference Include="System.Threading.AccessControl" Version="4.3.0" />
    <PackageReference Include="System.IO.FileSystem.Watcher" Version="4.3.0" />
    <PackageReference Include="System.Runtime.Serialization.Xml" Version="4.3.0" />
    <!-- WCF support for plugins that use NetNamedPipeBinding (e.g. HBRelogHelper).
         System.ServiceModel is no longer part of the .NET runtime starting with .NET 5+
         and must be supplied via NuGet. These packages ship the assemblies that get
         copied next to CopilotBuddy.exe so the runtime SourceCompiler can reference them. -->
    <PackageReference Include="System.ServiceModel.Primitives" Version="8.0.0" />
    <PackageReference Include="System.ServiceModel.NetNamedPipe" Version="8.0.0" />
  </ItemGroup>

</Project>
