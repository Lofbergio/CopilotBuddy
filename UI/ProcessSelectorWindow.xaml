<mah:MetroWindow x:Class="CopilotBuddy.UI.ProcessSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        x:Name="Window"
        Title="Select a WoW"
        Width="280"
        Height="123"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        TitleCharacterCasing="Normal"
        Icon="pack://application:,,,/Resources/bender.ico">
    <Grid x:Name="LayoutRoot">
        <TextBlock HorizontalAlignment="Left"
                   Margin="8,8,0,0"
                   TextWrapping="Wrap"
                   Text="Select the WoW process to attach to:"
                   VerticalAlignment="Top"
                   Foreground="#FFFFFFFF"/>
        <ComboBox x:Name="cbProcesses"
                  Margin="8,27.96,0,0"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Left"
                  Width="248.693"/>
        <Button x:Name="btnSelect"
                Content="Select"
                HorizontalAlignment="Left"
                Margin="8,53.92,0,0"
                VerticalAlignment="Top"
                Width="75"
                Click="btnSelect_Click"/>
        <Button x:Name="btnCancel"
                Content="Cancel"
                Margin="87,53.92,118,0"
                VerticalAlignment="Top"
                IsCancel="True"
                Click="btnCancel_Click"/>
        <Button x:Name="btnRefresh"
                Content="Refresh"
                HorizontalAlignment="Right"
                Margin="0,0,8,13.12"
                VerticalAlignment="Bottom"
                Width="75"
                Click="btnRefresh_Click"/>
    </Grid>
</mah:MetroWindow>
