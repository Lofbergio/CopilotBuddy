<mah:MetroWindow x:Class="CopilotBuddy.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:Styx.Localization"
        mc:Ignorable="d"
        x:Name="Window"
        Title="{loc:Resx AppTitle}"
        Icon="pack://application:,,,/Resources/bender.ico"
        Width="531"
        Height="350"
        MinWidth="350"
        MinHeight="229"
        WindowStartupLocation="CenterScreen"
        TitleCharacterCasing="Normal"
        Background="{DynamicResource WindowBackgroundBrush}"
        GlowBrush="{x:Null}"
        Closing="Window_Closing"
        Loaded="Window_Loaded">
    <Grid x:Name="LayoutRoot">
        <!-- Bot Selector ComboBox -->
        <ComboBox x:Name="cmbBotSelector"
                  IsEditable="False"
                  HorizontalAlignment="Right"
                  Margin="0,8,8,0"
                  VerticalAlignment="Top"
                  Width="120"
                  SelectionChanged="cmbBotSelector_SelectionChanged"/>

        <!-- Load Profile Button -->
        <Button x:Name="btnLoadProfile"
                HorizontalAlignment="Right"
                Margin="0,35,8,0"
                VerticalAlignment="Top"
                Height="25"
                Width="120"
                Click="btnLoadProfile_Click">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{loc:Resx LoadProfile}"/>
            </Viewbox>
        </Button>

        <!-- Settings Button -->
        <Button x:Name="btnSettings"
                Height="25"
                HorizontalAlignment="Right"
                Margin="0,62,8,0"
                VerticalAlignment="Top"
                Width="120"
                Click="btnSettings_Click">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{loc:Resx Settings}"/>
            </Viewbox>
        </Button>

        <!-- Enhanced Mode Checkbox -->
        <CheckBox x:Name="EnhancedMode"
                  HorizontalAlignment="Right"
                  Margin="0,115,8,0"
                  VerticalAlignment="Top"
                  Width="120"
                  ToolTip="Makes all buttons visible in the main window"
                  Content="{loc:Resx EnhancedMode}"
                  Unchecked="EnhancedMode_Unchecked"
                  Checked="EnhancedMode_Checked"/>

        <!-- Bot Config Button (hidden by default) -->
        <Button x:Name="btnBotConfig"
                Visibility="Hidden"
                Margin="0,135,8,0"
                VerticalAlignment="Top"
                Height="25"
                HorizontalAlignment="Right"
                Width="120"
                Click="btnBotConfig_Click">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{loc:Resx BotConfig}"/>
            </Viewbox>
        </Button>

        <!-- Class Config Button (hidden by default) -->
        <Button x:Name="btnClassConfig"
                Visibility="Hidden"
                Margin="0,161,8,0"
                VerticalAlignment="Top"
                Height="25"
                HorizontalAlignment="Right"
                Width="120"
                Click="btnClassConfig_Click">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{loc:Resx ClassConfig}"/>
            </Viewbox>
        </Button>

        <!-- Plugins Button (hidden by default) -->
        <Button x:Name="btnPlugins"
                Visibility="Hidden"
                Margin="0,187,8,0"
                VerticalAlignment="Top"
                Height="25"
                HorizontalAlignment="Right"
                Width="120"
                Click="btnPlugins_Click">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{loc:Resx Plugins}"/>
            </Viewbox>
        </Button>

        <!-- Dev Tools Button (hidden by default) -->
        <Button x:Name="btnDevTools"
                Height="25"
                Visibility="Hidden"
                Margin="0,213,8,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Width="120"
                Click="btnDevTools_Click">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{loc:Resx DeveloperTools}"/>
            </Viewbox>
        </Button>

        <!-- Start Button -->
        <Button x:Name="btnStart"
                HorizontalAlignment="Right"
                Margin="0,0,8,26"
                VerticalAlignment="Bottom"
                Width="120"
                Height="25"
                Click="btnStart_Click">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{loc:Resx Start}"/>
            </Viewbox>
        </Button>

        <!-- Stop/Pause SplitButton (hidden by default, shown when bot is running)     -->
        <!-- Mirrors HB 6.2.3: btnStop = db:SplitButton with Pause MenuItem dropdown.  -->
        <Grid x:Name="btnStopGroup"
              Visibility="Hidden"
              HorizontalAlignment="Right"
              Margin="0,0,8,26"
              VerticalAlignment="Bottom"
              Width="120"
              Height="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="17"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnStop"
                    Grid.Column="0"
                    Click="btnStop_Click">
                <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,2,0,2">
                    <TextBlock Text="{loc:Resx Stop}"/>
                </Viewbox>
            </Button>
            <Button x:Name="btnStopArrow"
                    Grid.Column="1"
                    Padding="0"
                    ToolTip="Pause / Resume"
                    Click="btnStopArrow_Click">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{loc:Resx Pause}" Click="btnPause_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
                <TextBlock Text="&#x25BC;" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
        </Grid>

        <!-- Tab Control (Log and Info tabs) -->
        <TabControl x:Name="tabControl"
                    Margin="8,8,132,25.96"
                    TabStripPlacement="Bottom">
            <TabItem Header="{loc:Resx TabLog}">
                <Grid>
                    <ScrollViewer x:Name="scrollLog" VerticalScrollBarVisibility="Auto">
                        <RichTextBox x:Name="rtbLog"
                                     Margin="0"
                                     IsReadOnly="True"
                                     UndoLimit="0"
                                     IsUndoEnabled="False"
                                     BorderBrush="{x:Null}">
                            <RichTextBox.Resources>
                                <Style TargetType="{x:Type Paragraph}">
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </RichTextBox.Resources>
                        </RichTextBox>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="{loc:Resx TabInfo}">
                <Grid>
                    <ScrollViewer x:Name="scrollInfo" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="tbInfoBlock"
                                 Margin="5,5,5,5"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 Background="#00FFFFFF"
                                 Foreground="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Margin="0"
                   VerticalAlignment="Bottom"
                   Background="{DynamicResource WindowBackgroundBrush}"
                   Panel.ZIndex="1">
            <StatusBarItem x:Name="lblActivityText"
                           Foreground="#FFFFFFFF"
                           Content="{loc:Resx Ready}"/>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
