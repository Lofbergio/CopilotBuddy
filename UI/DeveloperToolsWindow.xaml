<Window x:Class="CopilotBuddy.UI.DeveloperToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="Window" Title="Developer Tools" Width="711" MinWidth="711" Height="480" MinHeight="480"
        Background="#FF595959">
  <Window.Resources>
    <!-- Colors matching HB ExpressionDark theme -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF595959"/>
    <SolidColorBrush x:Key="NormalBrush" Color="#FF595959"/>
    <SolidColorBrush x:Key="NormalBorderBrush" Color="#FF333333"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#FF393939"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FF333333"/>
    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="#FF888888"/>
    <SolidColorBrush x:Key="GlyphBrush" Color="#FFD1D1D1"/>

    <!-- Button Style -->
    <Style TargetType="Button">
      <Setter Property="Background" Value="{StaticResource NormalBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#FF2A2A2A"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource DisabledForegroundBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ComboBox Style -->
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ComboBoxItem Style -->
    <Style TargetType="ComboBoxItem">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    </Style>

    <!-- CheckBox Style -->
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- TextBox Style -->
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
      <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- TabControl Style -->
    <Style TargetType="TabControl">
      <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
    </Style>

    <!-- TabItem Style with full template to ensure text is always readable -->
    <Style TargetType="TabItem">
      <Setter Property="Background" Value="{StaticResource NormalBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="Border" 
                    Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}" 
                    BorderThickness="1,1,1,0" 
                    Padding="8,4">
              <ContentPresenter x:Name="ContentSite" 
                                ContentSource="Header" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                TextBlock.Foreground="{StaticResource TextBrush}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource GlyphBrush}"/>
                <Setter TargetName="ContentSite" Property="TextBlock.Foreground" Value="{StaticResource TextBrush}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- GroupBox Style -->
    <Style TargetType="GroupBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
    </Style>

    <!-- ListView Style -->
    <Style TargetType="ListView">
      <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
    </Style>

    <!-- ListViewItem Style -->
    <Style TargetType="ListViewItem">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    </Style>

    <!-- TreeView Style -->
    <Style TargetType="TreeView">
      <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
    </Style>

    <!-- TreeViewItem Style -->
    <Style TargetType="TreeViewItem">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="IsExpanded" Value="False"/>
    </Style>

    <!-- ContextMenu Style -->
    <Style TargetType="ContextMenu">
      <Setter Property="Background" Value="{StaticResource NormalBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- MenuItem Style -->
    <Style TargetType="MenuItem">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Background" Value="{StaticResource NormalBrush}"/>
    </Style>

    <!-- ScrollViewer Style -->
    <Style TargetType="ScrollViewer">
      <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    </Style>

    <!-- GridViewColumnHeader Style -->
    <Style TargetType="GridViewColumnHeader">
      <Setter Property="Background" Value="{StaticResource NormalBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
    </Style>

    <!-- Header Arrow Templates -->
    <DataTemplate x:Key="HeaderTemplateArrowUp">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding}" Margin="0,0,4,0"/>
        <Polyline Points="0,4 4,0 8,4" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5"/>
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="HeaderTemplateArrowDown">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding}" Margin="0,0,4,0"/>
        <Polyline Points="0,0 4,4 8,0" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5"/>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>
  
  <Grid x:Name="LayoutRoot">
    <TabControl x:Name="tabControl" Margin="0">
      <!-- Tab: Profiles -->
      <TabItem Header="Profiles">
        <Grid>
          <GroupBox x:Name="groupBox" Header="Local Player Info" HorizontalAlignment="Left" Margin="8,8,0,0"
                    VerticalAlignment="Top" Height="62.96" Width="333">
            <Grid>
              <TextBlock x:Name="textBlock" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Position:"
                         Foreground="{StaticResource TextBrush}" Margin="8,8,0,0" VerticalAlignment="Top"/>
              <TextBlock MouseDown="tbLocalPlayerLocation_MouseDown" x:Name="tbLocalPlayerLocation" Margin="57.143,8,0,0"
                         TextWrapping="Wrap" Text="&lt;0, 0, 0&gt;" VerticalAlignment="Top" Foreground="{StaticResource TextBrush}"
                         HorizontalAlignment="Left" ToolTip="Double Click to Copy"/>
              <Button Click="btnRefreshPosition_Click" x:Name="btnRefreshPosition" Height="18"
                      HorizontalAlignment="Right" Margin="0,0,8,8" ToolTip="Refresh your position"
                      VerticalAlignment="Bottom" Width="18" Content="↻" FontSize="12" Padding="0"/>
            </Grid>
          </GroupBox>
          
          <GroupBox x:Name="groupBox_Copy" Header="Current Target Info" HorizontalAlignment="Left" Margin="8,74.96,0,0"
                    Width="333" Height="227" VerticalAlignment="Top">
            <Grid>
              <TextBlock x:Name="textBlock2" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Position:"
                         Foreground="{StaticResource TextBrush}" Margin="8,8,0,0" VerticalAlignment="Top"/>
              <TextBlock MouseDown="HandleTextBlockDoubleClick" x:Name="tbCTLocation" Margin="92,8,0,0"
                         TextWrapping="NoWrap" Text="0,0,0" VerticalAlignment="Top" Foreground="{StaticResource TextBrush}"
                         ToolTip="Double Click to Copy" HorizontalAlignment="Left"/>
              <TextBlock x:Name="textBlock2_Copy" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Name:"
                         Foreground="{StaticResource TextBrush}" Margin="8,27.96,0,0" VerticalAlignment="Top"/>
              <TextBlock MouseDown="HandleTextBlockDoubleClick" x:Name="tbCTName" Margin="92,27.96,0,0"
                         TextWrapping="NoWrap" Text="Empty" VerticalAlignment="Top" Foreground="{StaticResource TextBrush}"
                         ToolTip="Double Click to Copy" HorizontalAlignment="Left"/>
              <TextBlock x:Name="textBlock2_Copy1" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Entry (ID):"
                         Foreground="{StaticResource TextBrush}" Margin="8,47.92,0,0" VerticalAlignment="Top"/>
              <TextBlock MouseDown="HandleTextBlockDoubleClick" x:Name="tbCTEntry" Margin="92,47.92,0,0" TextWrapping="Wrap"
                         Text="0" Foreground="{StaticResource TextBrush}" ToolTip="Double Click to Copy" HorizontalAlignment="Left" Height="16"
                         VerticalAlignment="Top"/>
              <TextBlock x:Name="textBlock2_Copy2" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Faction ID:"
                         Foreground="{StaticResource TextBrush}" Margin="8,67.88,0,0" VerticalAlignment="Top"/>
              <TextBlock MouseDown="HandleTextBlockDoubleClick" x:Name="tbCTFactionId" Margin="92,67.88,0,0"
                         TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Foreground="{StaticResource TextBrush}"
                         ToolTip="Double Click to Copy" HorizontalAlignment="Left"/>
              <TextBlock x:Name="textBlock2_Copy3" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Faction Name:"
                         Foreground="{StaticResource TextBrush}" Margin="8,87.84,0,0" Height="15" VerticalAlignment="Top"/>
              <TextBlock MouseDown="HandleTextBlockDoubleClick" x:Name="tbCTFactionName" Margin="92,87.84,0,0"
                         TextWrapping="NoWrap" Text="Unknown" Foreground="{StaticResource TextBrush}" ToolTip="Double Click to Copy"
                         HorizontalAlignment="Left" Height="15" VerticalAlignment="Top"/>
              <TextBlock x:Name="textBlock2_Copy4" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Group ID:"
                         Foreground="{StaticResource TextBrush}" Margin="8,107,0,0" Height="16" VerticalAlignment="Top"/>
              <TextBlock MouseDown="HandleTextBlockDoubleClick" x:Name="tbCTGroup1" Margin="92,107,0,0" TextWrapping="Wrap"
                         Text="0" Foreground="{StaticResource TextBrush}" ToolTip="Double Click to Copy" HorizontalAlignment="Left" Height="16"
                         VerticalAlignment="Top"/>
              <TextBlock x:Name="textBlock2_Copy5" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Group ID 2:"
                         Foreground="{StaticResource TextBrush}" Margin="8,127,0,0" Height="16" VerticalAlignment="Top"/>
              <TextBlock MouseDown="HandleTextBlockDoubleClick" x:Name="tbCTGroup2" Margin="92,127,0,0" TextWrapping="Wrap"
                         Text="0" Foreground="{StaticResource TextBrush}" ToolTip="Double Click to Copy" HorizontalAlignment="Left" Height="16"
                         VerticalAlignment="Top"/>
              <TextBlock x:Name="textBlock2_Copy6" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Vendor Type:"
                         Foreground="{StaticResource TextBrush}" Margin="8,147,0,0" RenderTransformOrigin="0.485,-0.664" Height="16"
                         VerticalAlignment="Top"/>
              <TextBlock MouseDown="HandleTextBlockDoubleClick" x:Name="tbCTVendorType" Margin="92,147,0,0"
                         TextWrapping="Wrap" Text="None" Foreground="{StaticResource TextBrush}" ToolTip="Double Click to Copy"
                         HorizontalAlignment="Left" Height="16" VerticalAlignment="Top"/>
              <Button Click="btnCopyCTXmlInfo_Click" x:Name="btnCopyCTXmlInfo" Content="Copy XML" Margin="8,0,0,8"
                      VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="75"/>
              <Button Click="btnRefreshCTInfo_Click" x:Name="btnRefreshCTInfo" HorizontalAlignment="Right"
                      Margin="0,0,8,8" VerticalAlignment="Bottom" Width="18" Height="18"
                      ToolTip="Refresh current target info" Content="↻" FontSize="12" Padding="0"/>
            </Grid>
          </GroupBox>
          
          <GroupBox x:Name="groupBox2" Header="Quests" Margin="347.303,8,8,8">
            <Grid>
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TreeView x:Name="tvQuests">
                  <FrameworkElement.ContextMenu>
                    <ContextMenu>
                      <MenuItem Click="CopyQuestOrderXML" x:Name="CopyXML" Header="Copy XML"/>
                    </ContextMenu>
                  </FrameworkElement.ContextMenu>
                </TreeView>
              </ScrollViewer>
              <Button Click="btnRefreshQuests_Click" x:Name="btnRefreshQuests" HorizontalAlignment="Right"
                      Margin="0,0,8,8" VerticalAlignment="Bottom" Width="18" Height="18" ToolTip="Refresh Quests" Content="↻" FontSize="12" Padding="0"/>
              <Button Click="btnCopyAllQuests_Click" x:Name="btnCopyAllQuests" HorizontalAlignment="Right"
                      Margin="0,0,30,8" VerticalAlignment="Bottom" Width="18" Height="18" ToolTip="Copy All Quests" Content="📋" FontSize="11" Padding="0"/>
              <Button Click="btnCopyAllQuestOverrides_Click" x:Name="btnCopyAllQuestOverrides"
                      HorizontalAlignment="Right" Margin="0,0,53,8" VerticalAlignment="Bottom" Width="18" Height="18"
                      ToolTip="Copy All Quest Overrides" Content="📋" FontSize="11" Padding="0"/>
            </Grid>
          </GroupBox>
          
          <GroupBox x:Name="groupBox1" Header="Common" Margin="8,308,0,8" HorizontalAlignment="Left" Width="333">
            <Grid>
              <Button Click="btnGenerateBlackspot_Click" x:Name="btnGenerateBlackspot" Content="Generate Blackspot"
                      VerticalAlignment="Top" Margin="8,8,0,0" HorizontalAlignment="Left" Width="117"/>
              <Button Click="btnGenerateHotspot_Click" x:Name="btnGenerateHotspot" Content="Generate Hotspot"
                      VerticalAlignment="Top" Margin="8,32,0,0" HorizontalAlignment="Left" Width="117"/>
            </Grid>
          </GroupBox>
        </Grid>
      </TabItem>
      
      <!-- Tab: General -->
      <TabItem Header="General">
        <Grid>
          <GroupBox Name="groupBox_LootList" Header="Loot List" Margin="6,8,12,0" Width="671" Height="186"
                    VerticalAlignment="Top">
            <Grid>
              <ListView Name="lvLootList">
                <ListView.View>
                  <GridView>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name, Mode=OneTime}"/>
                    <GridViewColumn Header="Distance" DisplayMemberBinding="{Binding Distance, Mode=OneTime}"/>
                  </GridView>
                </ListView.View>
              </ListView>
            </Grid>
          </GroupBox>
          <GroupBox Name="groupBox_TargetList" Header="Target List" Margin="6,200,12,0" Height="186"
                    VerticalAlignment="Top" Width="671">
            <Grid>
              <ListView Name="lvTargetsList">
                <ListView.View>
                  <GridView>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name, Mode=OneTime}"/>
                    <GridViewColumn Header="Distance" DisplayMemberBinding="{Binding Distance, Mode=OneTime}"/>
                  </GridView>
                </ListView.View>
              </ListView>
            </Grid>
          </GroupBox>
        </Grid>
      </TabItem>
      
      <!-- Tab: Objects -->
      <TabItem Header="Objects">
        <Grid>
          <TabControl>
            <TabItem Header="Game Objects">
              <Grid>
                <ListView x:Name="lvGameObjectsDump" Margin="0" AlternationCount="1"
                          ButtonBase.Click="WoWObjectListViewColumn_OnClick">
                  <ListView.ContextMenu>
                    <ContextMenu>
                      <MenuItem x:Name="miCopyGameObjectInfo" Header="Copy Info" Click="CopyGameObjectInfo_OnClick"/>
                    </ContextMenu>
                  </ListView.ContextMenu>
                  <ListView.View>
                    <GridView>
                      <GridViewColumn Header="Entry" Width="50" DisplayMemberBinding="{Binding Entry, Mode=OneTime}"/>
                      <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name, Mode=OneTime}"/>
                      <GridViewColumn Header="GUID" Width="150" DisplayMemberBinding="{Binding Guid, Mode=OneTime}"/>
                      <GridViewColumn Header="Position" Width="120" DisplayMemberBinding="{Binding Location, Mode=OneTime}"/>
                      <GridViewColumn Header="Distance" Width="75" DisplayMemberBinding="{Binding Distance, Mode=OneTime}"/>
                      <GridViewColumn Header="Type" Width="75" DisplayMemberBinding="{Binding Type, Mode=OneTime}"/>
                      <GridViewColumn Header="Subtype" Width="90" DisplayMemberBinding="{Binding SubType, Mode=OneTime}"/>
                      <GridViewColumn Header="SpellFocus" Width="90" DisplayMemberBinding="{Binding SpellFocus, Mode=OneTime}"/>
                      <GridViewColumn Header="LockType" Width="90" DisplayMemberBinding="{Binding LockType, Mode=OneTime}"/>
                    </GridView>
                  </ListView.View>
                </ListView>
              </Grid>
            </TabItem>
            <TabItem Header="Units">
              <Grid>
                <ListView x:Name="lvUnitsDump" Margin="0" AlternationCount="1"
                          ButtonBase.Click="WoWObjectListViewColumn_OnClick">
                  <ListView.ContextMenu>
                    <ContextMenu>
                      <MenuItem x:Name="miCopyUnitInfo" Header="Copy Info" Click="CopyUnitInfo_OnClick"/>
                      <MenuItem x:Name="miViewAurasOnUnit" Header="View Auras" Click="ViewAurasOnUnit_OnClick"/>
                    </ContextMenu>
                  </ListView.ContextMenu>
                  <ListView.View>
                    <GridView>
                      <GridViewColumn Header="Entry" Width="50" DisplayMemberBinding="{Binding Entry, Mode=OneTime}"/>
                      <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name, Mode=OneTime}"/>
                      <GridViewColumn Header="GUID" Width="150" DisplayMemberBinding="{Binding Guid, Mode=OneTime}"/>
                      <GridViewColumn Header="Position" Width="120" DisplayMemberBinding="{Binding Location, Mode=OneTime}"/>
                      <GridViewColumn Header="Faction ID" Width="75" DisplayMemberBinding="{Binding FactionId, Mode=OneTime}"/>
                      <GridViewColumn Header="Distance" Width="75" DisplayMemberBinding="{Binding Distance, Mode=OneTime}"/>
                      <GridViewColumn Header="Type" Width="75" DisplayMemberBinding="{Binding Type, Mode=OneTime}"/>
                    </GridView>
                  </ListView.View>
                </ListView>
              </Grid>
            </TabItem>
            <TabItem Header="Bag Items">
              <Grid>
                <ListView x:Name="lvItemsDump" Margin="0" AlternationCount="1"
                          ButtonBase.Click="WoWObjectListViewColumn_OnClick">
                  <ListView.ContextMenu>
                    <ContextMenu>
                      <MenuItem x:Name="miCopyItemInfo" Header="Copy Info" Click="CopyItemInfo_OnClick"/>
                    </ContextMenu>
                  </ListView.ContextMenu>
                  <ListView.View>
                    <GridView>
                      <GridViewColumn Header="Entry" Width="50" DisplayMemberBinding="{Binding Entry, Mode=OneTime}"/>
                      <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name, Mode=OneTime}"/>
                      <GridViewColumn Header="StackCount" Width="90" DisplayMemberBinding="{Binding StackCount, Mode=OneTime}"/>
                      <GridViewColumn Header="Type" Width="90" DisplayMemberBinding="{Binding Type, Mode=OneTime}"/>
                    </GridView>
                  </ListView.View>
                </ListView>
              </Grid>
            </TabItem>
          </TabControl>
          <Button Click="btnRefreshObjectList_Click" x:Name="btnRefreshObjectList" HorizontalAlignment="Right"
                  Margin="2,2,8,8" VerticalAlignment="Top" Width="18" Height="18" ToolTip="Refresh object list" Content="↻" FontSize="12" Padding="0"/>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
